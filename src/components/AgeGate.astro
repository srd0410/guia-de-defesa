---
// Verificação de idade (autodeclaração) — exigida antes de liberar acesso ao site,
// dado o conteúdo sobre armas de fogo. Site inteiro, uma vez por visitante (localStorage).
// Ver lógica de exibição/ocultação em BaseLayout.astro (classe .gate-active no <html>,
// definida por script bloqueante no <head> para evitar flash de conteúdo).
---
<div id="age-gate" class="age-gate" role="dialog" aria-modal="true" aria-labelledby="age-gate-title">
  <div class="age-gate-box">
    <p class="age-gate-title" id="age-gate-title">Confirmação de idade</p>
    <p class="age-gate-text">
      Este site aborda armas de fogo, defesa pessoal e legislação relacionada, com conteúdo
      recomendado para maiores de 18 anos.
    </p>
    <p class="age-gate-question">Você confirma ser maior de 18 anos?</p>
    <div class="age-gate-actions">
      <button type="button" id="age-gate-yes" class="btn btn-yes">Sim, sou maior de 18 anos</button>
      <button type="button" id="age-gate-no" class="btn btn-no">Não</button>
    </div>
  </div>
</div>

<script>
  function gdSetAgeVerified() {
    try {
      localStorage.setItem('gd_age_ok', 'yes');
    } catch (e) {
      /* localStorage indisponível (modo privado etc.) — libera mesmo assim nesta sessão */
    }
    document.documentElement.classList.remove('gate-active');
  }

  function gdShowDenied() {
    const box = document.querySelector('#age-gate .age-gate-box');
    if (!box) return;
    box.innerHTML =
      '<p class="age-gate-title">Acesso não disponível</p>' +
      '<p class="age-gate-text">Este conteúdo não está disponível para menores de 18 anos.</p>';
  }

  function gdAttachHandlers() {
    document.getElementById('age-gate-yes')?.addEventListener('click', gdSetAgeVerified);
    document.getElementById('age-gate-no')?.addEventListener('click', gdShowDenied);
  }

  // Anexa imediatamente se o DOM já estiver pronto (evita corrida em que
  // 'DOMContentLoaded' já disparou antes deste script rodar); senão, espera o evento.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', gdAttachHandlers);
  } else {
    gdAttachHandlers();
  }
</script>

<style is:global>
  #age-gate { display: none; }
  html.gate-active #age-gate {
    display: flex;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
    background: var(--command);
    padding: 1.5rem;
  }
  html.gate-active #site-content { display: none; }
  html.gate-active body { overflow: hidden; }

  #age-gate .age-gate-box {
    max-width: 30rem;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius, 4px);
    padding: 2rem;
    text-align: center;
  }
  #age-gate .age-gate-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.3rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    color: var(--ink);
    margin: 0 0 0.9rem;
  }
  #age-gate .age-gate-text {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0 0 0.9rem;
  }
  #age-gate .age-gate-question {
    color: var(--ink);
    font-weight: 600;
    margin: 0 0 1.3rem;
  }
  #age-gate .age-gate-actions {
    display: flex;
    gap: 0.8rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  #age-gate .btn {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.7rem 1.3rem;
    border-radius: var(--radius, 4px);
    border: 1px solid transparent;
    cursor: pointer;
  }
  #age-gate .btn-yes {
    background: var(--olive);
    color: #fff;
  }
  #age-gate .btn-yes:hover { background: var(--olive-dk); }
  #age-gate .btn-no {
    background: transparent;
    color: var(--ink-soft);
    border-color: var(--line);
  }
  #age-gate .btn-no:hover { border-color: var(--steel); }
</style>
