---
// FAQ com schema FAQPage (JSON-LD) — legível por humanos e por mecanismos de IA.
// Uso no MDX:
//   import Faq from '../../components/Faq.astro';
//   <Faq items={[{ q: "Pergunta?", a: "Resposta direta em 1–3 frases." }]} />
interface FaqItem { q: string; a: string; }
interface Props { items: FaqItem[]; title?: string; }
const { items, title = 'Perguntas frequentes' } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a },
  })),
};
---
<section class="faq" aria-labelledby="faq-title">
  <h2 id="faq-title">{title}</h2>
  <dl>
    {items.map((it) => (
      <div class="qa">
        <dt>{it.q}</dt>
        <dd set:html={it.a} />
      </div>
    ))}
  </dl>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</section>

<style>
  .faq { margin: 2.4rem 0 1rem; }
  .faq h2 { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; }
  .faq dl { margin: 0; }
  .qa {
    border-bottom: 1px solid var(--line);
    padding: 1rem 0;
  }
  .qa dt {
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--ink);
    margin-bottom: 0.35rem;
  }
  .qa dd {
    margin: 0;
    color: var(--ink-soft);
  }
</style>
