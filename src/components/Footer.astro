---
import { SITE, CATEGORIES } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="wrap grid">
    <div class="col brandcol">
      <span class="brand-name">{SITE.name}</span>
      <p class="tagline">{SITE.description}</p>
    </div>
    <div class="col">
      <p class="eyebrow lite">Categorias</p>
      <ul>
        {CATEGORIES.map((c) => (
          <li><a href={`/categoria/${c.slug}/`}>{c.name}</a></li>
        ))}
      </ul>
    </div>
    <div class="col">
      <p class="eyebrow lite">O site</p>
      <ul>
        <li><a href="/artigos/">Todos os artigos</a></li>
        <li><a href="/sobre/">Sobre</a></li>
        <li><a href="/autor/">Autor</a></li>
        <li><a href="/politica-de-privacidade/">Política de Privacidade</a></li>
      </ul>
    </div>
  </div>
  <div class="wrap footer-bottom">
    <p class="philos-line">
      <a href="/sobre/" class="philos-label">Nossa filosofia</a>
      <span class="philos-pillars">Conhecimento · Preparação · Discernimento</span>
    </p>
    <p class="legal-text">© {year} {SITE.name}. Conteúdo informativo e educativo — não substitui orientação jurídica, médica ou profissional individualizada.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--command);
    color: #cfd6cf;
    margin-top: 4rem;
    padding: 3rem 0 1.5rem;
    border-top: 3px solid var(--olive);
  }
  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 2rem;
  }
  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.4rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #fff;
  }
  .tagline { font-size: 0.92rem; margin-top: 0.6rem; max-width: 34ch; }
  .eyebrow.lite { color: var(--brass); margin-bottom: 0.7rem; }
  .col ul { list-style: none; margin: 0; padding: 0; }
  .col li { margin-bottom: 0.45rem; }
  .col a { color: #cfd6cf; text-decoration: none; font-size: 0.92rem; }
  .col a:hover { color: #fff; }
  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--line-dk);
  }
  .philos-line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.35rem 0.9rem;
    margin: 0 0 0.9rem;
  }
  .philos-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--brass);
    text-decoration: none;
  }
  .philos-label:hover { color: #d59a3f; }
  .philos-pillars {
    font-family: var(--font-display);
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #e8ece6;
  }
  .legal-text { font-size: 0.78rem; color: #8c978f; margin: 0; }
  @media (max-width: 700px) {
    .grid { grid-template-columns: 1fr; gap: 1.6rem; }
  }
</style>
