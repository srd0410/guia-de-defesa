---
import { SITE, CATEGORIES } from '../consts';
const path = Astro.url.pathname;
---
<header class="site-header">
  <!-- Linha 1: logo -->
  <div class="wrap brand-row">
    <a href="/" class="brand" aria-label={`${SITE.name} — início`}>
      <img class="brand-logo" src="/logo-completo.jpg" alt={SITE.name} width="220" height="220" />
    </a>
    <p class="brand-tagline">{SITE.tagline}</p>
  </div>

  <!-- Linha 2: categorias em pills -->
  <div class="nav-bar">
    <div class="wrap">
      <nav class="primary-nav" aria-label="Categorias">
        <ul>
          {CATEGORIES.map((c) => (
            <li>
              <a
                href={`/categoria/${c.slug}/`}
                class:list={['pill', { active: path.startsWith(`/categoria/${c.slug}`) }]}
                aria-current={path.startsWith(`/categoria/${c.slug}`) ? 'page' : undefined}
              >
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  /* ── Linha 1: marca ─────────────────────────────── */
  .site-header {
    background: var(--command);
    color: #fff;
  }

  .brand-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1rem 0 0.75rem;
  }

  .brand {
    display: block;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-logo {
    height: 72px;
    width: auto;
    display: block;
    /* remove o fundo quadrado do jpg usando object-fit */
    object-fit: contain;
  }

  .brand-tagline {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #8a9e8a;
    margin: 0;
    line-height: 1.4;
    max-width: 28ch;
  }

  /* ── Linha 2: nav de categorias ─────────────────── */
  .nav-bar {
    background: var(--command-2);
    border-top: 1px solid var(--line-dk);
    border-bottom: 3px solid var(--olive);
  }

  .primary-nav ul {
    display: flex;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0.55rem 0;
    overflow-x: auto;
    scrollbar-width: none; /* Firefox */
    -ms-overflow-style: none; /* IE/Edge */
  }

  .primary-nav ul::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    text-decoration: none;
    white-space: nowrap;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    border: 1px solid var(--line-dk);
    color: #b0bcb0;
    background: transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
  }

  .pill:hover {
    background: var(--olive);
    border-color: var(--olive);
    color: #fff;
  }

  .pill.active {
    background: var(--brass);
    border-color: var(--brass);
    color: #fff;
  }

  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .brand-logo { height: 52px; }
    .brand-tagline { display: none; }
    .brand-row { padding: 0.75rem 0 0.6rem; }
  }
</style>
