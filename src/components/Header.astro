---
import { SITE, CATEGORIES } from '../consts';
import SearchBox from './SearchBox.astro';
const path = Astro.url.pathname;
---
<header class="site-header">
  <!-- Linha 1: banner full-width, com a busca sobreposta (Opção 4) -->
  <div class="banner-wrap">
    <a href="/" class="brand-band" aria-label={`${SITE.name} — início`}>
      <picture>
        <source srcset="/header-banner.webp" type="image/webp" />
        <img class="header-banner" src="/header-banner.jpeg" alt={SITE.name} width="1600" height="533" />
      </picture>
    </a>
    <SearchBox />
  </div>

  <!-- Linha 2: categorias em pills — 2 linhas de 5 -->
  <div class="nav-bar">
    <div class="wrap">
      <nav class="primary-nav" aria-label="Categorias">
        <ul>
          {CATEGORIES.map((c) => (
            <li>
              <a
                href={`/categoria/${c.slug}/`}
                class:list={['pill', { active: path.startsWith(`/categoria/${c.slug}`) }]}
                aria-current={path.startsWith(`/categoria/${c.slug}`) ? 'page' : undefined}
              >
                {c.name}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  /* ── Header geral ───────────────────────────────── */
  .site-header {
    background: var(--command);
    color: #fff;
    width: 100%;
  }

  /* ── Linha 1: banner full-width ─────────────────── */
  .banner-wrap {
    position: relative; /* âncora para a busca sobreposta (Opção 4) */
  }
  .brand-band {
    display: block;
    width: 100%;
    text-decoration: none;
    line-height: 0; /* remove espaço embaixo da imagem */
    border-bottom: 1px solid var(--line-dk);
  }

  .header-banner {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    max-height: 220px;
  }

  /* ── Linha 2: nav de categorias — 2 linhas de 5 ── */
  .nav-bar {
    background: var(--command-2);
    border-bottom: 3px solid var(--olive);
    width: 100%;
  }

  .primary-nav ul {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0.55rem 0;
  }

  .primary-nav li {
    display: flex;
  }

  .pill {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    text-align: center;
    padding: 0.35rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--line-dk);
    color: #b0bcb0;
    background: transparent;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1.2;
  }

  .pill:hover {
    background: var(--olive);
    border-color: var(--olive);
    color: #fff;
  }

  .pill.active {
    background: var(--brass);
    border-color: var(--brass);
    color: #fff;
  }

  /* ── Mobile ──────────────────────────────────────── */
  @media (max-width: 640px) {
    .header-banner { max-height: 100px; }
    .primary-nav ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
