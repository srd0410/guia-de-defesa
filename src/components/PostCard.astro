---
import { getCategory } from '../consts';
interface Props {
  url: string;
  title: string;
  description: string;
  category: string;
  pubDate: Date;
  feature?: boolean;
}
const { url, title, description, category, pubDate, feature = false } = Astro.props;
const cat = getCategory(category);
const date = pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
---
<article class={`card ${feature ? 'feature' : ''}`}>
  <a href={url} class="card-link">
    <div class="meta">
      <span class="cat">{cat?.name ?? category}</span>
      <span class="dot" aria-hidden="true">·</span>
      <time datetime={pubDate.toISOString()}>{date}</time>
    </div>
    <h3 class="title">{title}</h3>
    <p class="desc">{description}</p>
    <span class="more">Ler artigo →</span>
  </a>
</article>

<style>
  .card { border-top: 1px solid var(--line); padding: 1.5rem 0; }
  .card-link { display: block; text-decoration: none; color: inherit; }
  .meta { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.5rem; }
  .cat {
    font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--olive-dk); font-weight: 500;
  }
  .dot, time { font-family: var(--font-mono); font-size: 0.7rem; color: var(--steel); }
  .title { font-size: 1.5rem; margin: 0 0 0.4rem; transition: color 0.15s ease; }
  .card-link:hover .title { color: var(--olive-dk); }
  .desc { color: var(--ink-soft); margin: 0 0 0.6rem; }
  .more { font-family: var(--font-mono); font-size: 0.74rem; letter-spacing: 0.04em; color: var(--brass); }

  .card.feature { border-top: 0; padding: 0 0 1.5rem; }
  .card.feature .title { font-size: clamp(1.9rem, 4vw, 2.6rem); }
  .card.feature .desc { font-size: 1.1rem; }
</style>
