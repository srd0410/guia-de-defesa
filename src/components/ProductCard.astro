---
import { STORES, type StoreKey } from '../consts';

interface Props {
  /** Nome do produto */
  name: string;
  /** Link de AFILIADO (com o seu código de rastreio) */
  url: string;
  /** Loja: mercadolivre | amazon | shopee | aliexpress | outro */
  store?: StoreKey;
  /** URL da imagem do produto (opcional) */
  image?: string;
  /** Preço aproximado, ex.: 'R$ 189' (opcional) */
  price?: string;
  /** Sua recomendação curta de instrutor — é o "valor original" que o Google premia */
  take?: string;
}
const { name, url, store = 'outro', image, price, take } = Astro.props;
const s = STORES[store];
---
<div class="product" role="group" aria-label={`Recomendação: ${name}`}>
  <div class="product-head">
    <span class="eyebrow">Recomendação</span>
    <span class="store-badge" style={`background:${s.color}; color:${s.text}`}>{s.label}</span>
  </div>
  <div class="product-body">
    {image && (
      <div class="thumb"><img src={image} alt={name} loading="lazy" width="120" height="120" /></div>
    )}
    <div class="info">
      <h4 class="name">{name}</h4>
      {take && <p class="take"><slot>{take}</slot></p>}
      {!take && <p class="take"><slot /></p>}
      <div class="cta-row">
        <a class="btn" href={url} target="_blank" rel="sponsored nofollow noopener">
          Ver na {s.label}
        </a>
        {price && <span class="price">{price}</span>}
      </div>
    </div>
  </div>
</div>

<style>
  .product {
    border: 1px solid var(--line);
    border-left: 4px solid var(--olive);
    border-radius: var(--radius);
    background: #fff;
    margin: 1.8rem 0;
    overflow: hidden;
  }
  .product-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 1rem;
    background: var(--paper-2);
    border-bottom: 1px solid var(--line);
  }
  .store-badge {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 0.22rem 0.55rem;
    border-radius: 3px;
  }
  .product-body { display: flex; gap: 1.1rem; padding: 1.1rem; }
  .thumb { flex: 0 0 auto; }
  .thumb img { width: 120px; height: 120px; object-fit: contain; background: #fff; border: 1px solid var(--line); border-radius: 3px; }
  .info { flex: 1 1 auto; min-width: 0; }
  .name { font-size: 1.18rem; margin: 0 0 0.4rem; }
  .take { font-size: 0.95rem; color: var(--ink-soft); margin: 0 0 0.9rem; }
  .cta-row { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .price { font-family: var(--font-mono); font-weight: 500; color: var(--ink); }
  @media (max-width: 520px) {
    .product-body { flex-direction: column; }
    .thumb img { width: 100%; height: auto; }
  }
</style>
