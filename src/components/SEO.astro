---
// Canonical, Open Graph, Twitter Card e um único JSON-LD @graph (WebSite, Organization,
// Person = autor da casa, Article, BreadcrumbList) conectados por @id — mesmo padrão dos
// projetos irmãos (Guia de Voo, Regenere Saúde), para o Google e agentes de IA/GEO montarem
// a autoridade E-E-A-T entre o portal e o autor.
import { SITE, AUTHOR } from '../consts';

interface BreadcrumbItem {
  name: string;
  /** caminho relativo, ex.: '/categoria/equipamentos/'. Omita no último item para usar a página atual. */
  path?: string;
}

interface Props {
  title: string;
  description: string;
  /** caminho relativo, ex.: '/legitima-defesa-no-brasil/' */
  path: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  image?: string;
  /** Person JSON-LD do autor do artigo (usado p/ autor convidado; se ausente, cai no autor da casa). */
  authorPerson?: Record<string, unknown>;
  /** Person JSON-LD do editor/responsável editorial (autor convidado → Felipe entra como editor; se ausente e há convidado, cai no autor da casa). */
  editorPerson?: Record<string, unknown>;
  /** trilha de navegação (Início > Categoria > ...) para o schema BreadcrumbList */
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title, description, path,
  type = 'website',
  publishedTime, modifiedTime, author, image,
  authorPerson, editorPerson, breadcrumbs,
} = Astro.props;

const canonical = new URL(path, SITE.url).href;
const fullTitle = path === '/' ? `${SITE.name} — ${SITE.tagline}` : `${title} | ${SITE.name}`;
const ogImage = image ? new URL(image, SITE.url).href : new URL('/logo-completo.jpg', SITE.url).href;
const logoUrl = new URL('/logo-completo.jpg', SITE.url).href;

const organizationId = `${SITE.url}/#organization`;
const websiteId = `${SITE.url}/#website`;
const personId = new URL(AUTHOR.url, SITE.url).href + '#person';

const organization = {
  '@type': 'Organization',
  '@id': organizationId,
  name: SITE.name,
  url: SITE.url,
  logo: { '@type': 'ImageObject', url: logoUrl },
};

const website = {
  '@type': 'WebSite',
  '@id': websiteId,
  name: SITE.name,
  url: SITE.url,
  description: SITE.description,
  publisher: { '@id': organizationId },
};

// Autor da casa (Felipe) com E-E-A-T completo — um só nó Person, reaproveitado como
// author/editor padrão do Article e ligado à Organization via worksFor.
const houseAuthor = {
  '@type': 'Person',
  '@id': personId,
  name: AUTHOR.name,
  jobTitle: AUTHOR.role,
  description: AUTHOR.bio,
  knowsAbout: AUTHOR.knowsAbout,
  url: new URL(AUTHOR.url, SITE.url).href,
  worksFor: { '@id': organizationId },
};

const jsonLdGraph: Record<string, unknown>[] = [website, organization, houseAuthor];

if (type === 'article') {
  jsonLdGraph.push({
    '@type': 'Article',
    headline: title,
    description,
    author: authorPerson ?? { '@id': personId },
    // Autor convidado → Felipe entra como editor (responsável editorial), sinal de
    // supervisão que reforça E-E-A-T em conteúdo YMYL.
    ...(authorPerson ? { editor: editorPerson ?? { '@id': personId } } : {}),
    publisher: { '@id': organizationId },
    datePublished: publishedTime?.toISOString(),
    dateModified: (modifiedTime ?? publishedTime)?.toISOString(),
    mainEntityOfPage: canonical,
    image: ogImage,
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLdGraph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: item.name,
      item: new URL(item.path ?? path, SITE.url).href,
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': jsonLdGraph };
---
<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

<meta property="og:type" content={type} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale} />
<meta property="og:image" content={ogImage} />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
