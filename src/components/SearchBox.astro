---
// Campo de busca do site. Usa o índice do Pagefind (gerado no build) para
// buscar o TEXTO INTEIRO dos artigos.
//
// Duas variantes, mesmo motor de busca:
// - "banner" (padrão): campo sempre visível, sobreposto no banner do <Header>.
// - "compact": só um ícone de lupa; clicar expande um campo estreito. Usada
//   na StickyReadingBar (barra fixa ao rolar), onde o espaço é curto.
interface Props {
  variant?: 'banner' | 'compact';
}
const { variant = 'banner' } = Astro.props;
---
<div class={`site-search variant-${variant}`} role="search" data-variant={variant}>
  {variant === 'compact' && (
    <button type="button" class="search-toggle" aria-label="Buscar no site" aria-expanded="false">
      <svg class="search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    </button>
  )}
  <div class="search-field">
    {variant === 'banner' && (
      <svg class="search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
    )}
    <input
      class="search-input"
      type="search"
      placeholder="Buscar no site…"
      aria-label="Buscar no site"
      autocomplete="off"
      role="combobox"
      aria-expanded="false"
    />
    <div class="search-panel" hidden>
      <div class="search-results" role="listbox" aria-label="Resultados da busca"></div>
      <div class="search-foot"></div>
    </div>
  </div>
</div>

<style>
  .site-search {
    z-index: 5;
    display: flex;
    align-items: center;
  }

  /* ── Variante "banner": campo translúcido sobreposto (desktop) ──────── */
  .site-search.variant-banner {
    position: absolute;
    right: 1.5%;
    bottom: 7%;
    width: min(32%, 190px);
  }

  /* ── Variante "compact": ícone que expande (usada na barra fixa) ────── */
  .site-search.variant-compact {
    position: relative;
    flex-shrink: 0;
    gap: 0.35rem;
  }
  .search-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    background: transparent;
    border: 1px solid var(--line-dk);
    border-radius: 999px;
    color: #cfd6cf;
    cursor: pointer;
  }
  .search-toggle:hover { border-color: var(--olive); color: #fff; }
  .search-toggle .search-ico { width: 14px; height: 14px; }

  .search-field {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .variant-banner .search-field {
    background: rgba(34, 49, 42, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    padding: 0.35rem 0.65rem;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transition: background 0.12s, border-color 0.12s;
  }
  .variant-banner .search-field:focus-within {
    background: rgba(34, 49, 42, 0.55);
    border-color: var(--brass);
  }
  .search-ico {
    width: 13px;
    height: 13px;
    color: #eef2ee;
    flex: 0 0 auto;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.5));
  }
  .search-input {
    flex: 1;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
  }
  .search-input::placeholder { color: #e6ebe6; opacity: 1; }
  /* some o "x" nativo do input[type=search] para o visual ficar limpo */
  .search-input::-webkit-search-cancel-button { -webkit-appearance: none; }

  /* Campo estreito, colapsado até o usuário clicar na lupa */
  .variant-compact .search-field {
    width: 0;
    opacity: 0;
    padding: 0;
    overflow: hidden;
    pointer-events: none;
    border: 1px solid transparent;
    border-radius: 999px;
    transition: width 0.2s ease, opacity 0.15s ease, padding 0.2s ease, border-color 0.15s;
  }
  .variant-compact.expanded .search-field {
    width: 180px;
    opacity: 1;
    padding: 0.3rem 0.6rem;
    pointer-events: auto;
    background: rgba(255, 255, 255, 0.08);
    border-color: var(--line-dk);
  }
  .variant-compact.expanded .search-field:focus-within { border-color: var(--brass); }

  /* ── Painel de resultados (comum às duas variantes) ──────────────────── */
  .search-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(380px, 92vw);
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 3px solid var(--olive);
    border-radius: 6px;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    z-index: 60;
  }
  .search-panel[hidden] { display: none; }
  .search-results { max-height: min(60vh, 380px); overflow-y: auto; padding: 0.35rem; }
  .search-state {
    padding: 1.2rem 1rem;
    text-align: center;
    color: var(--steel);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .search-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 0.6rem 0.7rem;
    border-radius: 4px;
    border-left: 3px solid transparent;
  }
  .search-item:hover,
  .search-item:focus,
  .search-item.is-active {
    background: #fff;
    border-left-color: var(--brass);
    outline: none;
  }
  .search-item .r-cat {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--olive-dk);
  }
  .search-item .r-title {
    font-family: var(--font-display);
    font-size: 1.08rem;
    line-height: 1.15;
    margin: 0.12rem 0 0;
    color: var(--ink);
  }
  .search-item .r-snip { font-size: 0.84rem; color: var(--ink-soft); margin: 0.25rem 0 0; }
  .search-item mark { background: #f6e3bd; color: #5b3d0a; padding: 0 0.1em; border-radius: 2px; }
  .search-foot {
    padding: 0.5rem 0.85rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--steel);
    background: #fff;
  }
  .search-foot:empty { display: none; }

  /* ── Mobile: o banner é baixo demais para sobrepor —          ── */
  /*    o campo vira uma barra normal, largura total, abaixo do   */
  /*    banner e acima das categorias. Só se aplica à variante    */
  /*    "banner" — a "compact" (barra fixa) já é pequena por si.  */
  @media (max-width: 640px) {
    /* NB: precisa casar a especificidade da regra base (.site-search.variant-banner,
       duas classes) — senão a base "absolute/width:32%" vence por especificidade
       mesmo dentro do media query e o campo fica flutuando sobre o banner. */
    .site-search.variant-banner {
      position: static;
      width: auto;
      margin: 0.55rem 0.75rem 0;
    }
    .site-search.variant-banner .search-field { background: rgba(34, 49, 42, 0.6); }
    .site-search.variant-banner .search-panel { left: 0; right: 0; width: auto; }
    .variant-compact.expanded .search-field { width: 140px; }
  }
</style>

<script>
  type PagefindResult = {
    url: string;
    excerpt: string;
    meta: Record<string, string> & { title?: string };
  };

  let pagefindMod: any = null;
  let pagefindLoading: Promise<any> | null = null;

  // Carrega o Pagefind sob demanda (só quando o usuário interage). O caminho é
  // resolvido em runtime; o /* @vite-ignore */ evita o Vite tentar empacotar
  // esse import no build. Compartilhado por todas as instâncias do campo.
  async function loadPagefind() {
    if (pagefindMod) return pagefindMod;
    if (!pagefindLoading) {
      pagefindLoading = import(/* @vite-ignore */ '/pagefind/pagefind.js')
        .then(async (mod: any) => {
          await mod.options?.({ excerptLength: 18 });
          await mod.init?.();
          pagefindMod = mod;
          return mod;
        })
        .catch(() => null);
    }
    return pagefindLoading;
  }

  function escapeHtml(s: string) {
    return s.replace(/[&<>"]/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m] as string));
  }

  // Cada instância de .site-search (banner no Header, compact na barra fixa)
  // é inicializada de forma isolada, com elementos localizados por
  // querySelector dentro da própria raiz — evita colisão de ids entre instâncias.
  function initSearch(root: HTMLElement, index: number) {
    const variant = root.dataset.variant;
    const toggle = root.querySelector<HTMLButtonElement>('.search-toggle');
    const input = root.querySelector<HTMLInputElement>('.search-input');
    const panel = root.querySelector<HTMLElement>('.search-panel');
    const resultsEl = root.querySelector<HTMLElement>('.search-results');
    const footEl = root.querySelector<HTMLElement>('.search-foot');
    if (!input || !panel || !resultsEl || !footEl) return;

    panel.id = `site-search-panel-${index}`;
    input.setAttribute('aria-controls', panel.id);

    let debounce: number | undefined;
    let activeIndex = -1;

    function openPanel() {
      panel!.hidden = false;
      input!.setAttribute('aria-expanded', 'true');
    }
    function closePanel() {
      panel!.hidden = true;
      input!.setAttribute('aria-expanded', 'false');
      activeIndex = -1;
    }
    function setState(html: string) {
      resultsEl!.innerHTML = `<p class="search-state">${html}</p>`;
      footEl!.textContent = '';
      openPanel();
    }

    async function runSearch(query: string) {
      const q = query.trim();
      if (q.length < 2) {
        if (q.length === 0) closePanel();
        else setState('Digite ao menos 2 letras…');
        return;
      }
      const pf = await loadPagefind();
      if (!pf) {
        setState('A busca ainda não está disponível.<br>Recarregue a página em instantes.');
        return;
      }
      setState('Buscando…');
      const search = await pf.search(q);
      if (!search || search.results.length === 0) {
        setState(`Nenhum artigo encontrado para <strong>“${escapeHtml(q)}”</strong>.`);
        return;
      }
      const top = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));
      renderResults(top as PagefindResult[], search.results.length);
    }

    function renderResults(items: PagefindResult[], total: number) {
      activeIndex = -1;
      resultsEl!.innerHTML = items
        .map((it, i) => {
          const cat = it.meta?.categoria ? `<span class="r-cat">${escapeHtml(it.meta.categoria)}</span>` : '';
          const title = escapeHtml(it.meta?.title || 'Artigo');
          return `<a class="search-item" role="option" id="site-search-opt-${index}-${i}" href="${it.url}">
            ${cat}
            <p class="r-title">${title}</p>
            <p class="r-snip">${it.excerpt}</p>
          </a>`;
        })
        .join('');
      footEl!.textContent =
        total > items.length
          ? `Mostrando ${items.length} de ${total} artigos encontrados`
          : `${total} artigo${total > 1 ? 's' : ''} encontrado${total > 1 ? 's' : ''}`;
      openPanel();
    }

    // Navegação por teclado nos resultados
    function items() {
      return Array.from(resultsEl!.querySelectorAll<HTMLElement>('.search-item'));
    }
    function highlight(i: number) {
      const list = items();
      list.forEach((el) => el.classList.remove('is-active'));
      if (i >= 0 && i < list.length) {
        list[i].classList.add('is-active');
        list[i].scrollIntoView({ block: 'nearest' });
      }
      activeIndex = i;
    }

    function collapseCompact() {
      if (variant === 'compact') {
        root.classList.remove('expanded');
        toggle?.setAttribute('aria-expanded', 'false');
      }
    }

    if (toggle) {
      toggle.addEventListener('click', () => {
        const isExpanded = root.classList.toggle('expanded');
        toggle.setAttribute('aria-expanded', String(isExpanded));
        if (isExpanded) {
          loadPagefind();
          input.focus();
        } else {
          closePanel();
        }
      });
    }

    input.addEventListener('input', () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(() => runSearch(input.value), 180);
    });
    input.addEventListener('focus', () => {
      loadPagefind();
      if (input.value.trim().length >= 2 && resultsEl!.children.length) openPanel();
    });
    input.addEventListener('keydown', (e) => {
      const list = items();
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!panel!.hidden && list.length) highlight(Math.min(activeIndex + 1, list.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (!panel!.hidden && list.length) highlight(Math.max(activeIndex - 1, 0));
      } else if (e.key === 'Enter') {
        if (activeIndex >= 0 && list[activeIndex]) {
          e.preventDefault();
          (list[activeIndex] as HTMLAnchorElement).click();
        }
      } else if (e.key === 'Escape') {
        closePanel();
        collapseCompact();
        input.blur();
      }
    });

    // Fecha ao clicar fora (e recolhe o campo compact de volta ao ícone)
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) {
        closePanel();
        collapseCompact();
      }
    });
  }

  document.querySelectorAll<HTMLElement>('.site-search').forEach((root, i) => initSearch(root, i));
</script>
