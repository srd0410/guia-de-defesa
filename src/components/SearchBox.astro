---
// Campo de busca do site (Opção 4): fica sobreposto no banner, translúcido.
// Usa o índice do Pagefind (gerado no build) para buscar o TEXTO INTEIRO dos artigos.
// Aparece em todas as páginas porque é renderizado dentro do <Header>.
---
<div class="site-search" role="search">
  <div class="search-field">
    <svg class="search-ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" />
    </svg>
    <input
      id="site-search-input"
      class="search-input"
      type="search"
      placeholder="Buscar no site…"
      aria-label="Buscar no site"
      autocomplete="off"
      role="combobox"
      aria-expanded="false"
      aria-controls="site-search-panel"
    />
    <div id="site-search-panel" class="search-panel" hidden>
      <div id="site-search-results" class="search-results" role="listbox" aria-label="Resultados da busca"></div>
      <div class="search-foot" id="site-search-foot"></div>
    </div>
  </div>
</div>

<style>
  /* ── Campo translúcido no banner (desktop) ─────────────────── */
  .site-search {
    position: absolute;
    right: 1.5%;
    bottom: 7%;
    width: min(32%, 190px);
    z-index: 5;
  }
  .search-field {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(34, 49, 42, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 999px;
    padding: 0.35rem 0.65rem;
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.35), inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transition: background 0.12s, border-color 0.12s;
  }
  .search-field:focus-within {
    background: rgba(34, 49, 42, 0.55);
    border-color: var(--brass);
  }
  .search-ico {
    width: 13px;
    height: 13px;
    color: #eef2ee;
    flex: 0 0 auto;
    filter: drop-shadow(0 1px 1px rgba(0, 0, 0, 0.5));
  }
  .search-input {
    flex: 1;
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.82rem;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
  }
  .search-input::placeholder { color: #e6ebe6; opacity: 1; }
  /* some o "x" nativo do input[type=search] para o visual ficar limpo */
  .search-input::-webkit-search-cancel-button { -webkit-appearance: none; }

  /* ── Painel de resultados ──────────────────────────────────── */
  .search-panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    right: 0;
    width: min(380px, 92vw);
    background: var(--paper);
    border: 1px solid var(--line);
    border-top: 3px solid var(--olive);
    border-radius: 6px;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    z-index: 60;
  }
  .search-panel[hidden] { display: none; }
  .search-results { max-height: min(60vh, 380px); overflow-y: auto; padding: 0.35rem; }
  .search-state {
    padding: 1.2rem 1rem;
    text-align: center;
    color: var(--steel);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }
  .search-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 0.6rem 0.7rem;
    border-radius: 4px;
    border-left: 3px solid transparent;
  }
  .search-item:hover,
  .search-item:focus,
  .search-item.is-active {
    background: #fff;
    border-left-color: var(--brass);
    outline: none;
  }
  .search-item .r-cat {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--olive-dk);
  }
  .search-item .r-title {
    font-family: var(--font-display);
    font-size: 1.08rem;
    line-height: 1.15;
    margin: 0.12rem 0 0;
    color: var(--ink);
  }
  .search-item .r-snip { font-size: 0.84rem; color: var(--ink-soft); margin: 0.25rem 0 0; }
  .search-item mark { background: #f6e3bd; color: #5b3d0a; padding: 0 0.1em; border-radius: 2px; }
  .search-foot {
    padding: 0.5rem 0.85rem;
    border-top: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--steel);
    background: #fff;
  }
  .search-foot:empty { display: none; }

  /* ── Mobile: o banner é baixo demais para sobrepor —          ── */
  /*    o campo vira uma barra normal, largura total, abaixo do   */
  /*    banner e acima das categorias.                            */
  @media (max-width: 640px) {
    .site-search {
      position: static;
      width: auto;
      margin: 0.55rem 0.75rem 0;
    }
    .search-field { background: rgba(34, 49, 42, 0.6); }
    .search-panel { left: 0; right: 0; width: auto; }
  }
</style>

<script>
  type PagefindResult = {
    url: string;
    excerpt: string;
    meta: Record<string, string> & { title?: string };
  };

  const root = document.querySelector<HTMLElement>('.site-search');
  const input = document.getElementById('site-search-input') as HTMLInputElement | null;
  const panel = document.getElementById('site-search-panel') as HTMLElement | null;
  const resultsEl = document.getElementById('site-search-results') as HTMLElement | null;
  const footEl = document.getElementById('site-search-foot') as HTMLElement | null;

  if (root && input && panel && resultsEl && footEl) {
    let pagefind: any = null;
    let loading: Promise<any> | null = null;
    let debounce: number | undefined;
    let activeIndex = -1;

    // Carrega o Pagefind sob demanda (só quando o usuário interage).
    // O caminho é resolvido em runtime; o /* @vite-ignore */ evita o Vite tentar
    // empacotar esse import no build.
    async function loadPagefind() {
      if (pagefind) return pagefind;
      if (!loading) {
        loading = import(/* @vite-ignore */ '/pagefind/pagefind.js')
          .then(async (mod: any) => {
            await mod.options?.({ excerptLength: 18 });
            await mod.init?.();
            pagefind = mod;
            return mod;
          })
          .catch(() => null);
      }
      return loading;
    }

    function openPanel() {
      panel!.hidden = false;
      input!.setAttribute('aria-expanded', 'true');
    }
    function closePanel() {
      panel!.hidden = true;
      input!.setAttribute('aria-expanded', 'false');
      activeIndex = -1;
    }
    function setState(html: string) {
      resultsEl!.innerHTML = `<p class="search-state">${html}</p>`;
      footEl!.textContent = '';
      openPanel();
    }

    async function runSearch(query: string) {
      const q = query.trim();
      if (q.length < 2) {
        if (q.length === 0) closePanel();
        else setState('Digite ao menos 2 letras…');
        return;
      }
      const pf = await loadPagefind();
      if (!pf) {
        setState('A busca ainda não está disponível.<br>Recarregue a página em instantes.');
        return;
      }
      setState('Buscando…');
      const search = await pf.search(q);
      if (!search || search.results.length === 0) {
        setState(`Nenhum artigo encontrado para <strong>“${escapeHtml(q)}”</strong>.`);
        return;
      }
      const top = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));
      renderResults(top as PagefindResult[], search.results.length);
    }

    function renderResults(items: PagefindResult[], total: number) {
      activeIndex = -1;
      resultsEl!.innerHTML = items
        .map((it, i) => {
          const cat = it.meta?.categoria ? `<span class="r-cat">${escapeHtml(it.meta.categoria)}</span>` : '';
          const title = escapeHtml(it.meta?.title || 'Artigo');
          return `<a class="search-item" role="option" id="site-search-opt-${i}" href="${it.url}">
            ${cat}
            <p class="r-title">${title}</p>
            <p class="r-snip">${it.excerpt}</p>
          </a>`;
        })
        .join('');
      footEl!.textContent =
        total > items.length
          ? `Mostrando ${items.length} de ${total} artigos encontrados`
          : `${total} artigo${total > 1 ? 's' : ''} encontrado${total > 1 ? 's' : ''}`;
      openPanel();
    }

    function escapeHtml(s: string) {
      return s.replace(/[&<>"]/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[m] as string));
    }

    // Navegação por teclado nos resultados
    function items() {
      return Array.from(resultsEl!.querySelectorAll<HTMLElement>('.search-item'));
    }
    function highlight(i: number) {
      const list = items();
      list.forEach((el) => el.classList.remove('is-active'));
      if (i >= 0 && i < list.length) {
        list[i].classList.add('is-active');
        list[i].scrollIntoView({ block: 'nearest' });
      }
      activeIndex = i;
    }

    input.addEventListener('input', () => {
      window.clearTimeout(debounce);
      debounce = window.setTimeout(() => runSearch(input.value), 180);
    });
    input.addEventListener('focus', () => {
      loadPagefind();
      if (input.value.trim().length >= 2 && resultsEl!.children.length) openPanel();
    });
    input.addEventListener('keydown', (e) => {
      const list = items();
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (!panel!.hidden && list.length) highlight(Math.min(activeIndex + 1, list.length - 1));
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (!panel!.hidden && list.length) highlight(Math.max(activeIndex - 1, 0));
      } else if (e.key === 'Enter') {
        if (activeIndex >= 0 && list[activeIndex]) {
          e.preventDefault();
          (list[activeIndex] as HTMLAnchorElement).click();
        }
      } else if (e.key === 'Escape') {
        closePanel();
        input.blur();
      }
    });

    // Fecha ao clicar fora
    document.addEventListener('click', (e) => {
      if (!root.contains(e.target as Node)) closePanel();
    });
  }
</script>
