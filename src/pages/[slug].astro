---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import AdSlot from '../components/AdSlot.astro';
import AuthorBio from '../components/AuthorBio.astro';
import { getCategory, AUTHOR, SITE } from '../consts';

export async function getStaticPaths() {
  // Só gera página para posts publicados: não-rascunho e com data já alcançada.
  const posts = await getCollection('posts', ({ data }) => !data.draft && data.pubDate <= new Date());
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const cat = getCategory(post.data.category);
const date = post.data.pubDate.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
const updated = post.data.updatedDate?.toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });

// Autor convidado: quando presente, ele assina o artigo e Felipe entra como "Edição".
const guest = post.data.guestAuthor;
const guestIsExternal = guest?.url?.startsWith('http');

// Person JSON-LD passados ao SEO só no caso de convidado (senão o SEO usa o autor da casa).
const articleAuthorPerson = guest
  ? {
      '@type': 'Person',
      name: guest.name,
      ...(guest.credential ? { jobTitle: guest.credential } : {}),
      ...(guest.url ? { url: guest.url } : {}),
    }
  : undefined;
const articleEditorPerson = guest
  ? {
      '@type': 'Person',
      name: AUTHOR.name,
      jobTitle: AUTHOR.role,
      url: new URL(AUTHOR.url, SITE.url).href,
    }
  : undefined;

// Trilha (BreadcrumbList) — mesmo caminho mostrado visualmente em .crumbs, mas legível por
// máquina: Início → Categoria → Artigo. Ajuda o Google a exibir a trilha no resultado.
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Início', item: new URL('/', SITE.url).href },
    { '@type': 'ListItem', position: 2, name: cat?.name, item: new URL(`/categoria/${cat?.slug}/`, SITE.url).href },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: new URL(`/${post.slug}/`, SITE.url).href },
  ],
};
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={post.data.updatedDate ?? post.data.pubDate}
  author={guest ? guest.name : post.data.author}
  authorPerson={articleAuthorPerson}
  editorPerson={articleEditorPerson}
  stickyTitle={post.data.title}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
  <div class="post-layout wrap">
  <article class="post" data-pagefind-body>
    <nav class="crumbs" aria-label="Trilha" data-pagefind-ignore>
      <a href="/">Início</a> <span aria-hidden="true">/</span>
      <a href={`/categoria/${cat?.slug}/`}>{cat?.name}</a>
    </nav>

    <header class="post-head">
      <p class="eyebrow" data-pagefind-meta="categoria">{cat?.name}</p>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      <div class="byline" data-pagefind-ignore>
        {guest ? (
          <>
            <span>Por {guest.url
              ? <a href={guest.url} class="byline-author" target={guestIsExternal ? '_blank' : undefined} rel={guestIsExternal ? 'noopener nofollow' : undefined}>{guest.name}</a>
              : guest.name}</span>
            {guest.credential && <><span aria-hidden="true">·</span><span>{guest.credential}</span></>}
            <span aria-hidden="true">·</span>
            <span>Edição: <a href={AUTHOR.url} class="byline-author">{AUTHOR.name}</a></span>
          </>
        ) : (
          <span>Por <a href={AUTHOR.url} class="byline-author">{post.data.author}</a></span>
        )}
        <span aria-hidden="true">·</span>
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        {updated && <><span aria-hidden="true">·</span><span>atualizado em {updated}</span></>}
      </div>
    </header>

    {post.data.cover && (
      <img class="cover" src={post.data.cover.src} alt={post.data.coverAlt ?? ''} width={post.data.cover.width} height={post.data.cover.height} />
    )}

    {/* Artigo — topo. Fica logo após o 1º parágrafo (a introdução) via script abaixo —
        a posição SSR aqui (antes do <Content />) é só o fallback se o JS não rodar. */}
    <div id="ad-artigo-topo" data-pagefind-ignore>
      <AdSlot slot="6996990475" />
    </div>

    <div class="prose">
      <Content />
    </div>

    <script is:inline>
      (function () {
        var ad = document.getElementById('ad-artigo-topo');
        var firstPara = document.querySelector('.prose > p:first-of-type');
        if (ad && firstPara) {
          firstPara.insertAdjacentElement('afterend', ad);
        }
      })();
    </script>

    {post.data.affiliate && <div data-pagefind-ignore><AffiliateDisclosure /></div>}

    <div data-pagefind-ignore>
      <hr class="field-rule" />
      {/* Artigo — fim */}
      <AdSlot slot="9142019079" />

      {post.data.tags.length > 0 && (
        <div class="tags">
          {post.data.tags.map((t) => <span class="tag">#{t}</span>)}
        </div>
      )}

      <AuthorBio />
    </div>
  </article>

  <aside class="post-rail" data-pagefind-ignore>
    <div class="rail-ad-sticky">
      {/* Artigo — lateral (só desktop largo) */}
      <AdSlot slot="3165556671" />
    </div>
  </aside>
  </div>
</BaseLayout>

<style>
  .post-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2.5rem;
    padding-top: 2.2rem;
  }
  .post { max-width: 46rem; margin-inline: auto; width: 100%; }
  .post-rail { display: none; }
  .crumbs { font-family: var(--font-mono); font-size: 0.72rem; letter-spacing: 0.04em; color: var(--steel); margin-bottom: 1.4rem; }
  .crumbs a { color: var(--steel); text-decoration: none; }
  .crumbs a:hover { color: var(--olive-dk); }
  .post-head .eyebrow { color: var(--olive-dk); }
  .post-head h1 { margin: 0.5rem 0 0.6rem; }
  .dek { font-size: 1.2rem; color: var(--ink-soft); line-height: 1.5; }
  .byline { font-family: var(--font-mono); font-size: 0.74rem; color: var(--steel); display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem; }
  .byline-author { color: var(--olive-dk); text-decoration: none; }
  .byline-author:hover { color: var(--brass); }
  .cover { border-radius: var(--radius); margin: 1.8rem 0; border: 1px solid var(--line); }
  .tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.5rem; }
  .tag { font-family: var(--font-mono); font-size: 0.72rem; color: var(--steel); background: var(--paper-2); padding: 0.25rem 0.55rem; border-radius: 3px; }

  /* tipografia do corpo do artigo */
  .prose :global(h2) { border-bottom: 1px solid var(--line); padding-bottom: 0.3rem; }
  .prose :global(blockquote) {
    border-left: 4px solid var(--olive); margin: 1.6rem 0; padding: 0.4rem 0 0.4rem 1.2rem;
    color: var(--ink-soft); font-size: 1.12rem;
  }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.3rem; }
  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(code) { font-family: var(--font-mono); font-size: 0.9em; background: var(--paper-2); padding: 0.1em 0.35em; border-radius: 3px; }
  .prose :global(img) { border-radius: var(--radius); margin: 1.5rem 0; }
  .prose :global(strong) { font-weight: 600; }

  /* Coluna lateral com anúncio — só aparece em telas largas o bastante para não
     apertar a leitura. A pedido do autor, o limite é 1000px. O artigo tem
     prioridade sobre a lateral: de 1000 a 1199px a lateral fica fixa em 160px
     (largura mínima viável pra um anúncio vertical) e o artigo usa o resto até
     o teto de 46rem; a partir de 1200px, com mais espaço sobrando, a lateral
     cresce até 18rem. Sem isso, o Grid do CSS tende a "dar" o espaço extra pra
     lateral primeiro, deixando a leitura mais estreita do que antes de existir
     a lateral — o oposto do que se quer aqui. */
  @media (min-width: 1000px) {
    .post-layout {
      grid-template-columns: minmax(0, 46rem) 160px;
      justify-content: center;
    }
    .post-rail { display: block; }
    .rail-ad-sticky { position: sticky; top: 1.5rem; }
  }
  @media (min-width: 1200px) {
    .post-layout {
      grid-template-columns: minmax(0, 46rem) minmax(220px, 18rem);
    }
  }
</style>
