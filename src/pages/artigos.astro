---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { SITE, CATEGORIES } from '../consts';

// Mesmo critério de publicação usado na home e nas categorias.
const posts = (await getCollection('posts', ({ data }) => !data.draft && data.pubDate <= new Date()))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const PAGE_SIZE = 12;
---
<BaseLayout
  title="Todos os artigos"
  description={`Todos os artigos publicados no ${SITE.name}, do mais recente ao mais antigo.`}
  path="/artigos/"
  type="website"
>
  <section class="cat-head">
    <div class="wrap">
      <p class="eyebrow">Acervo completo</p>
      <h1>Todos os artigos</h1>
      <p class="blurb">{posts.length} artigos publicados. Use a busca e os filtros para encontrar o que precisa.</p>
    </div>
  </section>

  <div class="wrap controls" id="archive-controls">
    <input
      type="search"
      id="archive-search"
      class="archive-search"
      placeholder="Buscar por título ou tema..."
      aria-label="Buscar artigos"
    />
    <select id="archive-category" class="archive-select" aria-label="Filtrar por categoria">
      <option value="">Todas as categorias</option>
      {CATEGORIES.map((c) => <option value={c.slug}>{c.name}</option>)}
    </select>
    <select id="archive-sort" class="archive-select" aria-label="Ordenar por">
      <option value="recent">Mais recentes</option>
      <option value="updated">Mais atualizados</option>
    </select>
  </div>

  <p id="archive-count" class="archive-count wrap" aria-live="polite"></p>

  <div class="wrap stream" id="archive-stream">
    {posts.map((p) => (
      <div
        class="archive-item"
        data-title={p.data.title.toLowerCase()}
        data-description={p.data.description.toLowerCase()}
        data-category={p.data.category}
        data-pubdate={p.data.pubDate.valueOf()}
        data-updated={(p.data.updatedDate ?? p.data.pubDate).valueOf()}
      >
        <PostCard
          url={`/${p.slug}/`}
          title={p.data.title}
          description={p.data.description}
          category={p.data.category}
          pubDate={p.data.pubDate}
        />
      </div>
    ))}
  </div>

  <p id="archive-empty" class="archive-empty wrap" hidden>Nenhum artigo encontrado com esses filtros.</p>

  <nav class="wrap pagination" id="archive-pagination" aria-label="Paginação"></nav>
</BaseLayout>

<script define:vars={{ PAGE_SIZE }}>
  const stream = document.getElementById('archive-stream');
  const items = Array.from(stream.querySelectorAll('.archive-item'));
  const searchInput = document.getElementById('archive-search');
  const categorySelect = document.getElementById('archive-category');
  const sortSelect = document.getElementById('archive-sort');
  const countEl = document.getElementById('archive-count');
  const emptyEl = document.getElementById('archive-empty');
  const paginationEl = document.getElementById('archive-pagination');

  let page = 1;

  function apply() {
    const q = searchInput.value.trim().toLowerCase();
    const cat = categorySelect.value;
    const sortKey = sortSelect.value === 'updated' ? 'updated' : 'pubdate';

    let visible = items.filter((el) => {
      const matchesQuery = !q
        || el.dataset.title.includes(q)
        || el.dataset.description.includes(q);
      const matchesCategory = !cat || el.dataset.category === cat;
      return matchesQuery && matchesCategory;
    });

    visible.sort((a, b) => Number(b.dataset[sortKey]) - Number(a.dataset[sortKey]));

    items.forEach((el) => { el.style.display = 'none'; });

    countEl.textContent = visible.length === 0
      ? ''
      : `${visible.length} artigo${visible.length === 1 ? '' : 's'} encontrado${visible.length === 1 ? '' : 's'}`;
    emptyEl.hidden = visible.length !== 0;

    const totalPages = Math.max(1, Math.ceil(visible.length / PAGE_SIZE));
    page = Math.min(page, totalPages);
    const start = (page - 1) * PAGE_SIZE;
    const pageItems = visible.slice(start, start + PAGE_SIZE);

    pageItems.forEach((el) => {
      el.style.display = '';
      stream.appendChild(el);
    });

    renderPagination(totalPages);
  }

  function renderPagination(totalPages) {
    paginationEl.innerHTML = '';
    if (totalPages <= 1) return;
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(i);
      btn.className = 'page-btn' + (i === page ? ' active' : '');
      btn.setAttribute('aria-current', i === page ? 'page' : 'false');
      btn.addEventListener('click', () => {
        page = i;
        apply();
        stream.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      paginationEl.appendChild(btn);
    }
  }

  searchInput.addEventListener('input', () => { page = 1; apply(); });
  categorySelect.addEventListener('change', () => { page = 1; apply(); });
  sortSelect.addEventListener('change', () => { page = 1; apply(); });

  apply();
</script>

<style>
  .cat-head { background: var(--command); color: #fff; padding: 2.8rem 0; border-bottom: 3px solid var(--olive); }
  .cat-head .eyebrow { color: var(--brass); }
  .cat-head h1 { color: #fff; margin-top: 0.4rem; }
  .blurb { color: #cfd6cf; max-width: 56ch; margin-top: 0.6rem; }
  .stream { max-width: var(--measure); padding-top: 0.5rem; }

  .controls {
    max-width: var(--measure);
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    padding-top: 1.5rem;
  }
  .archive-search {
    flex: 1 1 220px;
    font: inherit;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }
  .archive-select {
    font: inherit;
    padding: 0.55rem 0.8rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
  }
  .archive-count {
    max-width: var(--measure);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--steel);
    margin: 0.8rem 0 0;
  }
  .archive-empty {
    max-width: var(--measure);
    color: var(--ink-soft);
    padding: 1rem 0;
  }
  .pagination {
    max-width: var(--measure);
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 1rem 0 2rem;
  }
  .page-btn {
    font: inherit;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--paper);
    cursor: pointer;
  }
  .page-btn:hover { border-color: var(--brass); }
  .page-btn.active { background: var(--olive); color: #fff; border-color: var(--olive); }
</style>
