---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES } from '../consts';

// Mostra o post quando NÃO é rascunho E a data de publicação já chegou.
// Assim: data futura agenda o post (aparece sozinho quando a data chega);
// draft: true segura o post manualmente, independentemente da data.
const posts = (await getCollection('posts', ({ data }) => !data.draft && data.pubDate <= new Date()))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const [lead, ...rest] = posts;
---
<BaseLayout title={SITE.name} description={SITE.description} path="/" type="website">
  <section class="masthead">
    <img class="masthead-emblem" src="/logo.jpg" alt="" aria-hidden="true" />
    <div class="wrap masthead-inner">
      <p class="eyebrow">Defesa · Equipamento · Prontidão</p>
      <h1>{SITE.tagline}</h1>
      <p class="lede">{SITE.description}</p>
    </div>
  </section>

  <div class="wrap content">
    {lead && (
      <section aria-label="Em destaque">
        <p class="eyebrow section-label">Última publicação</p>
        <PostCard
          url={`/${lead.slug}/`}
          title={lead.data.title}
          description={lead.data.description}
          category={lead.data.category}
          pubDate={lead.data.pubDate}
          feature={true}
        />
      </section>
    )}

    <hr class="field-rule" />

    <div class="layout">
      <section class="stream" aria-label="Publicações recentes">
        <p class="eyebrow section-label">Recentes</p>
        {rest.length === 0 && !lead && (
          <p class="empty">Ainda não há publicações. O primeiro artigo aparece aqui assim que for publicado.</p>
        )}
        {rest.map((p) => (
          <PostCard
            url={`/${p.slug}/`}
            title={p.data.title}
            description={p.data.description}
            category={p.data.category}
            pubDate={p.data.pubDate}
          />
        ))}
      </section>

      <aside class="rail" aria-label="Navegação por categoria">
        <p class="eyebrow section-label">Seções</p>
        <ul class="catlist">
          {CATEGORIES.map((c) => (
            <li><a href={`/categoria/${c.slug}/`}>{c.name}</a></li>
          ))}
        </ul>
        {/* Barra lateral da home. ID do slot: colar depois de criar a unidade "Home — lateral". */}
        <AdSlot slot="" />
      </aside>
    </div>
  </div>
</BaseLayout>

<style>
  .masthead {
    position: relative;
    overflow: hidden;
    background:
      radial-gradient(120% 140% at 85% -10%, rgba(176,125,43,0.18), transparent 55%),
      linear-gradient(165deg, var(--command-2) 0%, var(--command) 55%, #0e1712 100%);
    color: #fff;
    padding: 4.5rem 0 3.6rem;
    border-bottom: 1px solid var(--brass);
    box-shadow: inset 0 -4px 0 var(--olive);
  }
  .masthead-emblem {
    position: absolute;
    right: -40px; top: 50%;
    width: 360px; height: auto;
    transform: translateY(-50%);
    opacity: 0.16;
    mix-blend-mode: screen;
    pointer-events: none;
    user-select: none;
  }
  .masthead-inner { position: relative; z-index: 1; }
  .masthead .eyebrow {
    color: var(--brass);
    display: inline-flex; align-items: center; gap: 0.6rem;
  }
  .masthead .eyebrow::before {
    content: ""; width: 22px; height: 2px; background: var(--brass); display: inline-block;
  }
  .masthead h1 {
    color: #fff; max-width: 20ch; margin-top: 0.8rem;
    font-size: clamp(2.3rem, 5.5vw, 3.6rem);
    text-shadow: 0 1px 0 rgba(0,0,0,0.3);
  }
  .lede { color: #cfd6cf; max-width: 54ch; margin-top: 0.9rem; font-size: 1.12rem; }
  .content { padding-top: 2.8rem; }
  .section-label { margin-bottom: 1rem; }
  .layout { display: grid; grid-template-columns: 1fr 16rem; gap: 3rem; }
  .catlist { list-style: none; margin: 0 0 2rem; padding: 0; }
  .catlist li { border-top: 1px solid var(--line); }
  .catlist a {
    display: block; padding: 0.6rem 0; text-decoration: none; color: var(--ink);
    font-family: var(--font-display); font-size: 1.05rem; letter-spacing: 0.01em;
  }
  .catlist a:hover { color: var(--olive-dk); }
  .empty { color: var(--ink-soft); }
  @media (max-width: 880px) {
    .layout { grid-template-columns: 1fr; gap: 1.5rem; }
    .rail { order: -1; }
  }
</style>
